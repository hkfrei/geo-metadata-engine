digraph model_relations {
    rankdir=LR;
    node [shape=record, fontname="Helvetica"];

    // Nodes: fields show key FK and nullability
    Geopaeckli [label="{Geopaeckli|id}"];

    Ebene [label="{Ebene|id\lgeopaeckli_id : FK -> Geopaeckli (NOT NULL)\l}"];

    Wertetabelle [label="{Wertetabelle|id\lebene_id : FK -> Ebene (nullable)\lgeopaeckli_id : FK -> Geopaeckli (NOT NULL)\l}"];

    Attribut [label="{Attribut|id\lwertetabelle_id : FK -> Wertetabelle (nullable)\lgeopaeckli_id : FK -> Geopaeckli (nullable)\l}"];

    // Relationships (arrow direction = FK -> referenced model)
    Ebene -> Geopaeckli [label="ebene.geopaeckli_id\n1..*", arrowhead=normal];
    Wertetabelle -> Geopaeckli [label="wertetabelle.geopaeckli_id\n1..*", arrowhead=normal];
    Attribut -> Geopaeckli [label="attribut.geopaeckli_id\n0..* (nullable)", arrowhead=normal];

    Wertetabelle -> Ebene [label="wertetabelle.ebene_id\n0..* (nullable)", arrowhead=normal];
    Attribut -> Wertetabelle [label="attribut.wertetabelle_id\n0..* (nullable)", arrowhead=normal];

    // Meta label
    labelloc="t";
    label="Model relations — current state (2026-03-06)\nArrow: FK -> referenced model; labels show FK field and cardinality/nullability";
}
