digraph G {
  rankdir=LR;
  node [shape=record, fontname="Arial"];

  Geopaeckli [label="{Geopaeckli|thema FK -> Thema}"];
  Thema [label="{Thema}"];

  Ebene [label="{Ebene|geopaeckli FK -> Geopaeckli\ndienst FK -> Dienst\ntags M2M -> Tag\ntriggers M2M -> Trigger\nviews M2M -> View\nattributes_shared M2M -> Attribut}"];

  Attribut [label="{Attribut|geopaeckli FK -> Geopaeckli\nwertetabelle FK -> Wertetabelle}"];

  Wertetabelle [label="{Wertetabelle|ebene FK -> Ebene\ngeopaeckli FK -> Geopaeckli}"];

  Dienst [label="{Dienst|wertetabellen M2M -> Wertetabelle}"];
  View [label="{View|dienst FK -> Dienst}"];
  Map [label="{Map|dienste M2M -> Dienst}"];
  App [label="{App|map OneToOne -> Map}"];
  Layergroup [label="{Layergroup|layer M2M -> Layer}"];
  Layer [label="{Layer}"];
  Tag [label="{Tag}"];
  Trigger [label="{Trigger}"];
  Workflow [label="{Workflow|apps M2M -> App}"];
  Webmap [label="{Webmap}"];

  Geopaeckli -> Thema [label="thema FK", fontsize=10];
  Ebene -> Geopaeckli [label="geopaeckli FK", fontsize=10];
  Ebene -> Dienst [label="dienst FK", fontsize=10];
  Ebene -> Tag [label="tags M2M", dir=both, fontsize=10];
  Ebene -> Trigger [label="triggers M2M", dir=both, fontsize=10];
  Ebene -> View [label="views M2M", dir=both, fontsize=10];
  Ebene -> Attribut [label="attributes_shared M2M", dir=both, fontsize=10];
  Attribut -> Geopaeckli [label="geopaeckli FK", fontsize=10];
  Attribut -> Wertetabelle [label="wertetabelle FK", fontsize=10];
  Wertetabelle -> Ebene [label="ebene FK", fontsize=10];
  Wertetabelle -> Geopaeckli [label="geopaeckli FK", fontsize=10];
  Dienst -> Wertetabelle [label="wertetabellen M2M", dir=both, fontsize=10];
  View -> Dienst [label="dienst FK", fontsize=10];
  Map -> Dienst [label="dienste M2M", dir=both, fontsize=10];
  App -> Map [label="map OneToOne", fontsize=10];
  Layergroup -> Layer [label="layer M2M", dir=both, fontsize=10];
  Workflow -> App [label="apps M2M", dir=both, fontsize=10];
}
